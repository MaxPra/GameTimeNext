<Application
    x:Class="GameTimeNext.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converter="clr-namespace:GameTimeNext.Core.Application.Profiles.Converter"
    xmlns:local="clr-namespace:GameTimeNext"
    ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>

            <!--  Converter  -->
            <converter:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

            <ResourceDictionary.MergedDictionaries>

                <!--  Colors & Values  -->
                <ResourceDictionary Source="/GameTimeNext;component/UI/Colors/Colors.xaml" />
                <ResourceDictionary Source="/GameTimeNext;component/UI/Values/UIValues.xaml" />

                <!--  Control Styles  -->
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Controls/ButtonStyle.xaml" />
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Controls/TabControlStyle.xaml" />
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Controls/TileViewStyle.xaml" />
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Controls/ScrollViewStyle.xaml" />
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Controls/ToolTipStyle.xaml" />
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Controls/TextBoxStyle.xaml" />
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Controls/CheckBoxStyle.xaml" />
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Controls/PopupStyle.xaml" />
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Controls/TextBlockStyle.xaml" />
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Controls/GridViewStyle.xaml" />
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Controls/LoaderStyles.xaml" />
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Controls/ContextMenuStyles.xaml" />
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Controls/SearchBoxStyles.xaml" />
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Controls/MonitoringOverlayStyles.xaml" />
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Controls/LaunchingOverlayStyles.xaml" />
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Controls/ComboBoxStyles.xaml" />

                <!--  View Styles  -->
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Views/WindowStyle.xaml" />
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Views/ProfileDetailSubViewStyles.xaml" />
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Views/SteamGridDBViewStyles.xaml" />
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Views/SettingsViewStyles.xaml" />
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Views/ToastWindowStyles.xaml" />
                <ResourceDictionary Source="/GameTimeNext;component/UI/Styles/Views/ProfilesCropImageViewStyles.xaml" />

            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
