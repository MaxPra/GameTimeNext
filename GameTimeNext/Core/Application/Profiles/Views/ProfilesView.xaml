<uix:UIXUserControlBase
    x:Class="GameTimeNext.Core.Application.Profiles.Views.ProfilesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GameTimeNext.Core.Application.Profiles.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uix="clr-namespace:UIX.ViewController.Engine.FrameworkElements.UserControls;assembly=UIX.ViewController.Engine"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    HorizontalContentAlignment="Stretch"
    VerticalContentAlignment="Stretch"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        Background="Transparent">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2" />
            <ColumnDefinition
                Width="420"
                MinWidth="420"
                MaxWidth="1000" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Column="0"
            Padding="0"
            Background="Transparent">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox
                        x:Name="tbSearchProfileName"
                        Grid.Column="0"
                        Width="320"
                        Height="38"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource TextBox.Default}"
                        Tag="Search for name"
                        ToolTip="Search for name" />

                    <Grid
                        Grid.Column="1"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center">
                        <Button
                            x:Name="BtnFilter"
                            Width="38"
                            Height="38"
                            VerticalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="14"
                                Text="" />
                        </Button>

                        <Popup
                            x:Name="PopFilter"
                            AllowsTransparency="True"
                            Placement="Right"
                            PlacementTarget="{Binding ElementName=BtnFilter}"
                            StaysOpen="True">
                            <Border
                                Padding="12"
                                Background="{DynamicResource Brush.Surface}"
                                BorderBrush="{DynamicResource Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource DefaultCornerRadius}"
                                Style="{StaticResource ModernPopupCardStyle}">
                                <ContentPresenter x:Name="CPFilter" />
                            </Border>
                        </Popup>
                    </Grid>

                    <Button
                        x:Name="BtnAddProfile"
                        Grid.Column="3"
                        Width="38"
                        Height="38"
                        Margin="0,0,16,0"
                        VerticalAlignment="Center"
                        ToolTip="Add profile">
                        <Image
                            Width="16"
                            Height="16"
                            Source="/UI/Ressources/GTN_ICON_ADD_PROFILE.png"
                            Stretch="Uniform" />
                    </Button>
                </Grid>

                <ListBox
                    x:Name="ListBoxProfiles"
                    Grid.Row="1"
                    Padding="{StaticResource TileListPaddingTopOnly}"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemsSource="{Binding T1Profis}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    SelectedItem="{Binding SelectedT1Profi, Mode=TwoWay}"
                    SelectionMode="Single">

                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemContainerStyle>
                        <Style BasedOn="{StaticResource TileListBoxItemStyle}" TargetType="{x:Type ListBoxItem}">
                            <Setter Property="Margin" Value="{StaticResource TileItemMargin}" />
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu Style="{StaticResource ModernContextMenuStyle}">
                                        <MenuItem
                                            x:Name="ctxtEdit"
                                            Header="Edit"
                                            Style="{StaticResource ModernContextMenuItemStyle}">
                                            <MenuItem.Icon>
                                                <TextBlock
                                                    FontFamily="Segoe MDL2 Assets"
                                                    FontSize="14"
                                                    Foreground="{DynamicResource Brush.TextSecondary}"
                                                    Text="" />
                                            </MenuItem.Icon>
                                        </MenuItem>

                                        <Separator Style="{StaticResource ModernContextMenuSeparatorStyle}" />

                                        <MenuItem
                                            x:Name="ctxtDelete"
                                            Header="Delete"
                                            Style="{StaticResource ModernContextMenuItemStyle}">
                                            <MenuItem.Icon>
                                                <TextBlock
                                                    FontFamily="Segoe MDL2 Assets"
                                                    FontSize="14"
                                                    Foreground="{DynamicResource Brush.TextSecondary}"
                                                    Text="" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                </ListBox>
            </Grid>
        </Border>

        <GridSplitter
            Grid.Column="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="{DynamicResource Brush.Border}"
            Cursor="SizeWE"
            ResizeBehavior="PreviousAndNext"
            ResizeDirection="Columns"
            ShowsPreview="False" />

        <Border
            Grid.Column="2"
            Padding="16"
            Background="Transparent">
            <ContentPresenter x:Name="CPProfileDetailView" />
        </Border>

    </Grid>
</uix:UIXUserControlBase>