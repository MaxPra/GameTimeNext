<Window
    x:Class="GameTimeNext.Core.Framework.UI.ToastMessage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="ToastMessage"
    Width="360"
    Height="132"
    AllowsTransparency="True"
    Background="Transparent"
    Focusable="False"
    Loaded="Window_Loaded"
    ResizeMode="NoResize"
    ShowActivated="False"
    ShowInTaskbar="False"
    Topmost="True"
    WindowStartupLocation="Manual"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.Resources>
        <Storyboard x:Key="ToastProgressStoryboard">
            <DoubleAnimation
                FillBehavior="HoldEnd"
                Storyboard.TargetName="ProgressScale"
                Storyboard.TargetProperty="ScaleX"
                From="1"
                To="0"
                Duration="0:0:4" />
        </Storyboard>
    </Window.Resources>

    <Window.Effect>
        <DropShadowEffect
            BlurRadius="22"
            Direction="270"
            Opacity="0.35"
            ShadowDepth="0"
            Color="#A0000000" />
    </Window.Effect>

    <Grid
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True">

        <Border Style="{StaticResource ToastRootBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource ToastAccentBarStyle}" />

                <Grid Grid.Column="1" Margin="16,14,16,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Name="TbTitle"
                            Grid.Column="0"
                            Style="{StaticResource ToastTitleTextStyle}"
                            Text="Info" />

                        <TextBlock
                            x:Name="TbCategory"
                            Grid.Column="1"
                            Margin="12,0,0,0"
                            Style="{StaticResource ToastCategoryTextStyle}"
                            Text="GameTimeNext" />
                    </Grid>

                    <Border Grid.Row="1" Style="{StaticResource ToastDividerStyle}" />

                    <TextBlock
                        x:Name="TbMessage"
                        Grid.Row="2"
                        Margin="0,2,0,0"
                        Style="{StaticResource ToastMessageTextStyle}"
                        Text="Text" />

                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            x:Name="TbTimestamp"
                            Grid.Row="0"
                            Style="{StaticResource ToastSecondaryTextStyle}"
                            Text="Right now" />

                        <Grid Grid.Row="1" Margin="0,6,0,0">
                            <Border Style="{StaticResource ToastProgressTrackStyle}" />
                            <Border Style="{StaticResource ToastProgressBarStyle}">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="ProgressScale" ScaleX="1" ScaleY="1" />
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource ToastProgressStoryboard}" />
        </EventTrigger>
    </Window.Triggers>
</Window>