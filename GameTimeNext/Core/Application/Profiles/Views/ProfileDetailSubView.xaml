<uixcontrols:UIXUserControlBase
    x:Class="GameTimeNext.Core.Application.Profiles.Views.ProfileDetailSubView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uixprops="clr-namespace:UIX.ViewController.Engine.AttachedProperties;assembly=UIX.ViewController.Engine"
    xmlns:uixcontrols="clr-namespace:UIX.ViewController.Engine.FrameworkElements.UserControls;assembly=UIX.ViewController.Engine"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid Style="{StaticResource ProfileDetail.Root}">
        <Grid Style="{StaticResource ProfileDetail.Container}">

            <DockPanel Style="{StaticResource ProfileDetail.Layout}">

                <!-- Buttons: fixed at bottom -->
                <Border DockPanel.Dock="Bottom"
                        Style="{StaticResource ProfileDetail.ButtonHost}"
                        Margin="0,26,0,6">
                    <StackPanel Style="{StaticResource ProfileDetail.ButtonArea}">
                        <Button Style="{StaticResource App.Button.Primary}"
                                Content="Launch game"/>

                        <Button Style="{StaticResource App.Button.Secondary}"
                                Content="Start Monitoring"/>
                    </StackPanel>
                </Border>

                <!-- Content above buttons -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Title -->
                        <RowDefinition Height="*"/>
                        <!-- Body -->
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <Grid Grid.Row="0"
                          Width="{StaticResource ProfileDetail.CoverWidth}"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource ProfileDetail.Title}"
                                   uixprops:UIXAttachedProperty.Path="TBL_PROFI.GANA"/>
                    </Grid>

                    <!-- Body -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- Cover -->
                            <RowDefinition Height="10"/>
                            <!-- small gap cover -> info -->
                            <RowDefinition Height="Auto"/>
                            <!-- Infos -->
                            <RowDefinition Height="*"/>
                            <!-- free space below infos -->
                        </Grid.RowDefinitions>

                        <!-- Cover -->
                        <Viewbox Grid.Row="0"
                                 Stretch="Uniform"
                                 StretchDirection="DownOnly"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Top"
                                 MaxHeight="520">
                            <Border Style="{StaticResource ProfileDetail.CoverFrame}"
                                    Margin="0">
                                <Grid>
                                    <Image Style="{StaticResource ProfileDetail.CoverImage}"
                                           uixprops:UIXAttachedProperty.Path="TBL_PROFI.PPFN"/>
                                    <Border Style="{StaticResource ProfileDetail.CoverOverlay}"/>
                                </Grid>
                            </Border>
                        </Viewbox>

                        <!-- Infos -->
                        <Border Grid.Row="2" Style="{StaticResource ProfileDetail.InfoHost}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="1" Style="{StaticResource ProfileDetail.InfoCard}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="18"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Style="{StaticResource ProfileDetail.GameTimeLabel}"
                                                   Text="Game time:"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2"
                                                   Style="{StaticResource ProfileDetail.GameTimeValue}"
                                                   uixprops:UIXAttachedProperty.Path="TBL_PROFI.GATI"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                   Style="{StaticResource ProfileDetail.InfoLabel}"
                                                   Text="First time played:"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2"
                                                   Style="{StaticResource ProfileDetail.InfoValue}"
                                                   uixprops:UIXAttachedProperty.Path="TBL_PROFI.FIPL"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0"
                                                   Style="{StaticResource ProfileDetail.InfoLabel}"
                                                   Text="Last time played:"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2"
                                                   Style="{StaticResource ProfileDetail.InfoValue}"
                                                   uixprops:UIXAttachedProperty.Path="TBL_PROFI.LAPL"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                    </Grid>

                </Grid>

            </DockPanel>

        </Grid>
    </Grid>
</uixcontrols:UIXUserControlBase>