<uixcontrols:UIXUserControlBase x:Class="GameTimeNext.Core.Application.Profiles.Views.ProfilesFilterPopupView"
                                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                                xmlns:uixcontrols="clr-namespace:UIX.ViewController.Engine.FrameworkElements.UserControls;assembly=UIX.ViewController.Engine"
                                MinWidth="560">

    <Border Background="{DynamicResource Brush.Surface}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0"
            CornerRadius="{StaticResource DefaultCornerRadius}"
            Padding="16">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Library filters"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.TextPrimary}"
                       Margin="0,0,0,12"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <!-- TAGS -->
                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                    <TextBlock Text="TAGS"
                               Foreground="{DynamicResource Brush.Accent}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <!-- optional: Search -->
                    <TextBox x:Name="TxtSearchTag"
                             Height="30"
                             Margin="0,0,0,10"
                             ToolTip="Search tags" 
                             Style="{StaticResource TextBox.Modern}"
                             Tag="Search tags"/>

                    <Border BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource DefaultCornerRadius}"
                            Padding="10">

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="250">

                            <ItemsControl ItemsSource="{Binding Tbl_Groups}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Style="{StaticResource Checkbox.Default}"
                                                  Content="{Binding GRNA}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Margin="0,0,0,6"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>

                <!-- PLAY STATUS -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="STATE"
                               Foreground="{DynamicResource Brush.Accent}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <Border BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource DefaultCornerRadius}"
                            Padding="10">

                        <ItemsControl ItemsSource="{Binding States}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Style="{StaticResource Checkbox.Default}"
                                              Content="{Binding GRNA}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Margin="0,0,0,6"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,14,0,0">

                <Button x:Name="BtnCancel"
                        Content="Cancel"
                        Width="90"
                        Height="34"
                        Margin="0,0,10,0"
                        Style="{StaticResource Button.Primary}"/>

                <Button x:Name="BtnApply"
                        Content="Apply"
                        Width="90"
                        Height="34"
                        Style="{StaticResource Button.Secondary}" />
            </StackPanel>
        </Grid>
    </Border>
</uixcontrols:UIXUserControlBase>