<uix:UIXUserControlHostBase
    x:Class="GameTimeNext.Core.Application.Profiles.Views.ProfilesSubView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GameTimeNext.Core.Application.Profiles.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uix="clr-namespace:UIX.ViewController.Engine.FrameworkElements.UserControls;assembly=UIX.ViewController.Engine"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    HorizontalContentAlignment="Stretch"
    VerticalContentAlignment="Stretch"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Background="{DynamicResource Brush.Background}"
    mc:Ignorable="d">

    <Grid
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        Background="{DynamicResource Brush.Surface}"
        Cursor="">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="2" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  LINKER BEREICH  -->
        <Border
            Grid.Column="0"
            Padding="16"
            Background="Transparent">
            <Grid>
                <ListBox
                    x:Name="ListBoxProfiles"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemsSource="{Binding Tbl_Profis}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    SelectedItem="{Binding SelectedTBLPROFI, Mode=TwoWay}"
                    SelectionMode="Single">

                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemContainerStyle>
                        <Style BasedOn="{StaticResource TileListBoxItemStyle}" TargetType="{x:Type ListBoxItem}">
                            <Setter Property="Margin" Value="{StaticResource TileGap}" />
                        </Style>
                    </ListBox.ItemContainerStyle>

                </ListBox>
            </Grid>
        </Border>

        <!--  SPLITTER  -->
        <GridSplitter
            Grid.Column="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="{DynamicResource Brush.Border}"
            Cursor="SizeWE"
            ResizeBehavior="PreviousAndNext"
            ResizeDirection="Columns"
            ShowsPreview="False" />

        <!--  RECHTER BEREICH  -->
        <Border
            Grid.Column="2"
            Padding="16"
            Background="Transparent">
            <ContentPresenter x:Name="CPProfileDetailView"/>
        </Border>
    </Grid>
</uix:UIXUserControlHostBase>
