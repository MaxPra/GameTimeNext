<ui:GTNWindow
    x:Class="GameTimeNext.Core.Application.Profiles.Views.ProfilesSteamGridDBView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GameTimeNext.Core.Application.Profiles.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="clr-namespace:GameTimeNext.Core.Framework.UI.Base"
    Title="Select SteamGridDB cover"
    Width="1100"
    Height="760"
    MinWidth="980"
    MinHeight="620"
    ResizeMode="CanResize"
    ShowMaximizeButton="False"
    ShowMinimizeButton="False"
    Style="{StaticResource GTNWindowStyle}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="16,0,16,0">
            <TextBlock
                FontSize="22"
                FontWeight="SemiBold"
                Text="Select SteamGridDB cover" />

            <TextBlock
                Margin="0,34,0,0"
                Opacity="0.75"
                Text="Choose a cover image for the profile." />
        </Grid>

        <Border
            Grid.Row="2"
            Margin="16,0,16,0"
            Padding="16"
            Background="#08FFFFFF"
            BorderBrush="#1FFFFFFF"
            BorderThickness="1"
            CornerRadius="{DynamicResource DefaultCornerRadius}">
            <Grid>
                <ListBox
                    x:Name="lbSteamGridCovers"
                    ItemsSource="{Binding Images}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    SelectedItem="{Binding SelectedImage, Mode=TwoWay}"
                    SelectionMode="Single"
                    Style="{StaticResource SteamGridDBCoverListBoxStyle}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid
                                Width="170"
                                Height="270"
                                ClipToBounds="True"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                                <Border
                                    Margin="0"
                                    Background="#0A0D14"
                                    ClipToBounds="True"
                                    CornerRadius="{StaticResource DefaultCornerRadius}">
                                    <Image
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        SnapsToDevicePixels="True"
                                        Source="{Binding BitmapImage}"
                                        Stretch="UniformToFill"
                                        UseLayoutRounding="True" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Row="4" Margin="16,0,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="btnPreviousPage"
                Grid.Column="0"
                Width="130"
                Height="36"
                Content="Previous Page" />

            <Button
                x:Name="btnNextPage"
                Grid.Column="2"
                Width="130"
                Height="36"
                Content="Next Page" />

            <Button
                x:Name="btnCancel"
                Grid.Column="4"
                Width="110"
                Height="36"
                Content="Cancel" />

            <Button
                x:Name="btnApply"
                Grid.Column="6"
                Width="140"
                Height="36"
                Content="Apply" />
        </Grid>
    </Grid>
</ui:GTNWindow>