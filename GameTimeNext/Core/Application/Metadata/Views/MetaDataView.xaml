<uix:UIXUserControlBase
    x:Class="GameTimeNext.Core.Application.Metadata.MetaDataView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GameTimeNext.Core.Application.Metadata"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uix="clr-namespace:UIX.ViewController.Engine.FrameworkElements.UserControls;assembly=UIX.ViewController.Engine"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Top Area  -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="500" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Table Object  -->
            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="Table Object:" />

            <TextBox
                x:Name="txtTableObject"
                Grid.Row="0"
                Grid.Column="1"
                Height="30"
                VerticalContentAlignment="Center" />

            <!--  Description  -->
            <TextBlock
                Grid.Row="1"
                Grid.Column="0"
                Margin="0,8,0,0"
                VerticalAlignment="Center"
                Text="Description:" />

            <TextBox
                x:Name="txtDescription"
                Grid.Row="1"
                Grid.Column="1"
                Height="30"
                Margin="0,8,0,0"
                VerticalContentAlignment="Center" />
        </Grid>

        <!--  GridView  -->
        <ListView Grid.Row="2">
            <ListView.View>
                <GridView>
                    <GridViewColumn
                        Width="200"
                        DisplayMemberBinding="{Binding Name}"
                        Header="Name" />
                    <GridViewColumn
                        Width="140"
                        DisplayMemberBinding="{Binding Type}"
                        Header="Type" />
                    <GridViewColumn
                        Width="90"
                        DisplayMemberBinding="{Binding IsNullable}"
                        Header="Nullable" />
                    <GridViewColumn
                        Width="300"
                        DisplayMemberBinding="{Binding Description}"
                        Header="Description" />
                </GridView>
            </ListView.View>
        </ListView>

    </Grid>
</uix:UIXUserControlBase>