<ui:GTNWindow
    x:Class="GameTimeNext.Core.Application.General.FavAppsReorder.Views.FavAppsReorderView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GameTimeNext.Core.Application.General.FavAppsReorder.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="clr-namespace:GameTimeNext.Core.Framework.UI.Base"
    Title="Favorite Apps Reorder"
    Width="800"
    Height="600"
    MinWidth="600"
    MinHeight="400"
    ShowMaximizeButton="False"
    ShowMinimizeButton="False"
    Style="{StaticResource GTNWindowStyle}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid Margin="20">
        <!--  Applications List  -->
        <Border
            Background="{DynamicResource Brush.Surface}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="{StaticResource DefaultCornerRadius}">
            <ListView
                x:Name="lvFavAppsReorder"
                AllowDrop="True"
                ItemsSource="{Binding FavoriteApplications}"
                SelectedItem="{Binding SelectedApplication, Mode=TwoWay}"
                SelectionMode="Single"
                Style="{StaticResource ListView.DragDrop}">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextBlock
                            FontSize="13"
                            Foreground="{DynamicResource Brush.TextPrimary}"
                            Text="{Binding AppName}"
                            TextTrimming="CharacterEllipsis" />
                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>
        </Border>
    </Grid>
</ui:GTNWindow>
