<ui:GTNWindow
    x:Class="GameTimeNext.Core.Application.General.AppSearch.Views.AppSearchView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:GameTimeNext.Core.Application.General.AppSearch.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="clr-namespace:GameTimeNext.Core.Framework.UI.Base"
    Title="Application Search"
    Width="800"
    Height="600"
    MinWidth="600"
    MinHeight="400"
    ShowMaximizeButton="False"
    ShowMinimizeButton="False"
    Style="{StaticResource GTNWindowStyle}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Search Bar  -->
        <Border
            Grid.Row="0"
            Height="40"
            Margin="0,0,0,12"
            Background="{DynamicResource Brush.TextBox.Background}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="{StaticResource DefaultCornerRadius}">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="14"
                    Foreground="{DynamicResource Brush.TextSecondary}"
                    Text="&#xE721;" />

                <TextBox
                    x:Name="txbSearch"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    CaretBrush="{DynamicResource Brush.TextPrimary}"
                    FontSize="13"
                    Foreground="{DynamicResource Brush.TextPrimary}"
                    Tag="Search applications..." />
            </Grid>
        </Border>

        <!--  Applications List  -->
        <Border
            Grid.Row="1"
            Background="{DynamicResource Brush.Surface}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="{StaticResource DefaultCornerRadius}">
            <ListView
                x:Name="lvApplicationSearch"
                Background="Transparent"
                BorderThickness="0"
                ItemsSource="{Binding SearchableApplications}"
                SelectedItem="{Binding SelectedSearchableApplication, Mode=TwoWay}"
                SelectionMode="Single">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                FontSize="13"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Brush.Accent}"
                                Text="{Binding Code, StringFormat='[{0}]'}" />
                            <TextBlock
                                Margin="8,0,0,0"
                                FontSize="13"
                                Foreground="{DynamicResource Brush.TextPrimary}"
                                Text="{Binding Name}"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>
        </Border>
    </Grid>
</ui:GTNWindow>
