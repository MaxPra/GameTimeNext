<ui:GTNWindow
    x:Class="GameTimeNext.Core.Framework.UI.Dialogs.CFMBOXView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="clr-namespace:GameTimeNext.Core.Framework.UI.Base"
    Title="Question"
    Width="560"
    MinWidth="560"
    MinHeight="220"
    MaxWidth="820"
    MaxHeight="700"
    ResizeMode="NoResize"
    ShowInTaskbar="True"
    ShowMaximizeButton="False"
    ShowMinimizeButton="False"
    SizeToContent="Height"
    Style="{StaticResource GTNWindowStyle}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="22"
            Background="{DynamicResource Brush.Surface}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="{DynamicResource DefaultCornerRadius}">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    x:Name="BdIconHost"
                    Grid.Column="0"
                    Width="56"
                    Height="56"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="{DynamicResource Brush.Warning}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1"
                    CornerRadius="8">

                    <TextBlock
                        x:Name="TbIconGlyph"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="26"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource Brush.TextPrimary}"
                        Text="?" />
                </Border>

                <ScrollViewer
                    Grid.Column="2"
                    MaxHeight="360"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Focusable="False"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">

                    <TextBlock
                        x:Name="TbMessage"
                        FontSize="15"
                        FontWeight="Normal"
                        Foreground="{DynamicResource Brush.TextPrimary}"
                        LineHeight="24"
                        Text="Message"
                        TextWrapping="Wrap" />
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="BtnButton1"
                Grid.Column="1"
                Height="36"
                MinWidth="110"
                Margin="0,0,10,0"
                Padding="18,0"
                Content="OK"
                Visibility="Collapsed" />

            <Button
                x:Name="BtnButton2"
                Grid.Column="2"
                Height="36"
                MinWidth="110"
                Margin="0,0,10,0"
                Padding="18,0"
                Content="No"
                Visibility="Collapsed" />

            <Button
                x:Name="BtnButton3"
                Grid.Column="3"
                Height="36"
                MinWidth="110"
                Padding="18,0"
                Content="Cancel"
                Visibility="Collapsed" />
        </Grid>
    </Grid>
</ui:GTNWindow>