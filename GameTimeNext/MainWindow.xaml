    Title="GameTimeNXT"
    Width="1350"
    Height="1000"
    MinWidth="1350"
    MinHeight="1000"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    HorizontalContentAlignment="Stretch"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    ApplicationSearchItemsSource="{Binding AvailableApplications}"
    ApplicationSearchPlaceholder="Search Application"
    ApplicationSearchSelectedItem="{Binding SelectedApplication}"
    ShowApplicationSearch="True"
    Style="{StaticResource GTNWindowStyle}"
    Subtitle="BETA"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    mc:Ignorable="d">

    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

        <TabControl
            x:Name="MainTabControl"
            Padding="0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            Background="Transparent"
            BorderThickness="0"
