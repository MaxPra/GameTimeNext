<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Effects="clr-namespace:System.Windows.Media.Effects;assembly=PresentationCore">

    <!--  Global default ToolTip  -->
    <Style TargetType="{x:Type ToolTip}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="HasDropShadow" Value="False" />
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        <Setter Property="Padding" Value="12,9" />
        <Setter Property="MaxWidth" Value="420" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToolTip}">
                    <Grid SnapsToDevicePixels="True">

                        <!--  Outer shadow  -->
                        <Border
                            Margin="0"
                            Background="Transparent"
                            CornerRadius="{StaticResource DefaultCornerRadius}">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="18"
                                    Opacity="0.28"
                                    ShadowDepth="0"
                                    Color="{DynamicResource Color.Background}" />
                            </Border.Effect>
                        </Border>

                        <!--  Accent glow frame  -->
                        <Border
                            Background="{DynamicResource Brush.Accent}"
                            CornerRadius="{StaticResource DefaultCornerRadius}"
                            Opacity="0.18" />

                        <!--  Main tooltip body  -->
                        <Border
                            Margin="1"
                            Background="{DynamicResource Brush.Surface}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource DefaultCornerRadius}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="2" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!--  Top accent line  -->
                                <Border
                                    Grid.Row="0"
                                    Background="{DynamicResource Brush.Accent}"
                                    CornerRadius="9,9,0,0" />

                                <!--  Content  -->
                                <Border
                                    Grid.Row="1"
                                    Padding="{TemplateBinding Padding}"
                                    Background="Transparent">
                                    <ContentPresenter RecognizesAccessKey="True">
                                        <ContentPresenter.Resources>
                                            <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
                                                <Setter Property="TextWrapping" Value="Wrap" />
                                                <Setter Property="TextTrimming" Value="None" />
                                                <Setter Property="LineHeight" Value="18" />
                                            </Style>
                                        </ContentPresenter.Resources>
                                    </ContentPresenter>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Explicit tooltip for profile titles  -->
    <Style
        x:Key="ProfileTitleToolTipStyle"
        BasedOn="{StaticResource {x:Type ToolTip}}"
        TargetType="{x:Type ToolTip}">
        <Setter Property="Placement" Value="Bottom" />
        <Setter Property="HorizontalOffset" Value="0" />
        <Setter Property="VerticalOffset" Value="12" />

        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />

        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="MaxWidth" Value="560" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToolTip}">
                    <Grid SnapsToDevicePixels="True">

                        <!--  Soft outer shadow  -->
                        <Border Background="Transparent" CornerRadius="{StaticResource DefaultCornerRadius}">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="22"
                                    Opacity="0.35"
                                    ShadowDepth="0"
                                    Color="{DynamicResource Color.Background}" />
                            </Border.Effect>
                        </Border>

                        <!--  Accent outer shell  -->
                        <Border
                            Background="{DynamicResource Brush.Accent}"
                            CornerRadius="12"
                            Opacity="0.22" />

                        <!--  Main shell  -->
                        <Border
                            Margin="1"
                            Background="{DynamicResource Brush.Surface}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource DefaultCornerRadius}">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="3" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!--  Stronger accent top bar  -->
                                <Border
                                    Grid.Row="0"
                                    Background="{DynamicResource Brush.Accent}"
                                    CornerRadius="{StaticResource DefaultCornerRadius}" />

                                <!--  Inner content area  -->
                                <Border
                                    Grid.Row="1"
                                    Margin="0"
                                    Padding="{TemplateBinding Padding}"
                                    Background="Transparent">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!--  Left accent bar  -->
                                        <Border
                                            Grid.Column="0"
                                            Background="{DynamicResource Brush.Accent}"
                                            CornerRadius="{StaticResource DefaultCornerRadius}"
                                            Opacity="0.9" />

                                        <!--  Content  -->
                                        <ContentPresenter
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            RecognizesAccessKey="True">
                                            <ContentPresenter.Resources>
                                                <Style TargetType="{x:Type TextBlock}">
                                                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
                                                    <Setter Property="TextWrapping" Value="Wrap" />
                                                    <Setter Property="TextTrimming" Value="None" />
                                                    <Setter Property="LineHeight" Value="20" />
                                                </Style>
                                            </ContentPresenter.Resources>
                                        </ContentPresenter>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>