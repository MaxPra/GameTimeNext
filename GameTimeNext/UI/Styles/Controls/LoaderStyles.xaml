<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Accent Brushes (Dynamic)  -->
    <SolidColorBrush x:Key="Brush.LoaderAccent" Color="{DynamicResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.LoaderAccentHover" Color="{DynamicResource Color.AccentHover}" />
    <SolidColorBrush x:Key="Brush.LoaderAccentPressed" Color="{DynamicResource Color.AccentPressed}" />

    <!--  Loader Overlay Style  -->
    <Style x:Key="GTNLoadingOverlayStyle" TargetType="{x:Type ContentControl}">
        <Setter Property="Panel.ZIndex" Value="999" />
        <Setter Property="Visibility" Value="Collapsed" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContentControl}">

                    <Grid
                        x:Name="Root"
                        Background="#7A000000"
                        IsHitTestVisible="True">

                        <Border
                            Height="3"
                            Margin="18,56,18,0"
                            VerticalAlignment="Top"
                            Background="#22000000"
                            ClipToBounds="True"
                            CornerRadius="2">

                            <Grid>
                                <Border
                                    Width="160"
                                    HorizontalAlignment="Left"
                                    CornerRadius="2">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Offset="0" Color="#00FFFFFF" />
                                            <GradientStop Offset="0.35" Color="{DynamicResource Color.AccentHover}" />
                                            <GradientStop Offset="0.5" Color="{DynamicResource Color.Accent}" />
                                            <GradientStop Offset="0.65" Color="{DynamicResource Color.AccentHover}" />
                                            <GradientStop Offset="1" Color="#00FFFFFF" />
                                        </LinearGradientBrush>
                                    </Border.Background>

                                    <Border.Effect>
                                        <DropShadowEffect
                                            BlurRadius="18"
                                            Opacity="0.85"
                                            ShadowDepth="0"
                                            Color="{DynamicResource Color.Accent}" />
                                    </Border.Effect>

                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="GlowTranslate" X="-220" />
                                    </Border.RenderTransform>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="Visibility" Value="Visible">
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="LoaderStoryboard">
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetName="GlowTranslate"
                                            Storyboard.TargetProperty="X"
                                            From="-220"
                                            To="1800"
                                            Duration="0:0:1.10" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>

                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="LoaderStoryboard" />
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>