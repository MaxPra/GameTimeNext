<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="MonitoringOverlayHostStyle" TargetType="{x:Type ContentControl}">
        <Setter Property="Visibility" Value="Collapsed" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Panel.ZIndex" Value="1000" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContentControl}">
                    <Grid Background="#96060A10">
                        <Border
                            Width="430"
                            MinHeight="250"
                            Padding="30"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="{DynamicResource Brush.Surface}"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource DefaultCornerRadius}">

                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="28"
                                    Direction="270"
                                    Opacity="0.24"
                                    ShadowDepth="0"
                                    Color="{DynamicResource Color.Accent}" />
                            </Border.Effect>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid
                                    Grid.Row="0"
                                    Width="138"
                                    Height="138"
                                    Margin="0,0,0,24"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                                    <Grid
                                        Width="138"
                                        Height="138"
                                        RenderTransformOrigin="0.5,0.5">
                                        <Grid.RenderTransform>
                                            <RotateTransform x:Name="OuterRotateTransform" Angle="0" />
                                        </Grid.RenderTransform>

                                        <Ellipse
                                            Width="104"
                                            Height="104"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Opacity="0.55"
                                            Stroke="{DynamicResource Brush.Border}"
                                            StrokeDashArray="2 6"
                                            StrokeThickness="1.5" />

                                        <Ellipse
                                            Width="118"
                                            Height="118"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Opacity="0.8"
                                            Stroke="{DynamicResource Brush.Accent}"
                                            StrokeDashArray="10 18"
                                            StrokeDashCap="Round"
                                            StrokeThickness="2" />

                                        <Ellipse
                                            Width="10"
                                            Height="10"
                                            Margin="0,5,0,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Top"
                                            Fill="{DynamicResource Brush.Accent}" />
                                    </Grid>

                                    <Grid
                                        Width="88"
                                        Height="88"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        RenderTransformOrigin="0.5,0.5">
                                        <Grid.RenderTransform>
                                            <ScaleTransform x:Name="CenterPulseTransform" ScaleX="1" ScaleY="1" />
                                        </Grid.RenderTransform>

                                        <Border
                                            Background="#18000000"
                                            BorderBrush="{DynamicResource Brush.Accent}"
                                            BorderThickness="1.5"
                                            CornerRadius="44" />

                                        <Border
                                            Margin="10"
                                            Background="{DynamicResource Brush.Accent}"
                                            CornerRadius="34"
                                            Opacity="0.1" />

                                        <Grid
                                            Width="34"
                                            Height="34"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Rectangle
                                                Grid.Row="0"
                                                Width="5"
                                                Height="14"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Bottom"
                                                Fill="{DynamicResource Brush.TextPrimary}"
                                                RadiusX="2"
                                                RadiusY="2" />

                                            <Rectangle
                                                Grid.Row="1"
                                                Width="16"
                                                Height="4"
                                                Margin="0,4,0,0"
                                                HorizontalAlignment="Center"
                                                Fill="{DynamicResource Brush.TextPrimary}"
                                                RadiusX="2"
                                                RadiusY="2" />

                                            <Path
                                                Width="10"
                                                Height="10"
                                                Margin="0,0,-4,-2"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Data="M 0,0 L 10,5 L 0,10 Z"
                                                Fill="{DynamicResource Brush.Accent}" />
                                        </Grid>

                                        <Rectangle
                                            x:Name="ScanLine"
                                            Width="54"
                                            Height="4"
                                            Margin="0,18,0,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Top"
                                            Fill="{DynamicResource Brush.TextPrimary}"
                                            Opacity="0.2"
                                            RadiusX="2"
                                            RadiusY="2">
                                            <Rectangle.RenderTransform>
                                                <TranslateTransform x:Name="ScanTranslateTransform" Y="0" />
                                            </Rectangle.RenderTransform>
                                        </Rectangle>
                                    </Grid>
                                </Grid>

                                <TextBlock
                                    Grid.Row="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource Brush.TextPrimary}"
                                    Text="Currently monitoring game time..."
                                    TextAlignment="Center" />

                                <TextBlock
                                    x:Name="StatusText"
                                    Grid.Row="2"
                                    Margin="0,10,0,0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    Foreground="{DynamicResource Brush.TextSecondary}"
                                    Opacity="0.9"
                                    Text="Tracking active session"
                                    TextAlignment="Center" />
                            </Grid>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="Visibility" Value="Visible">
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="MonitoringOverlayStoryboard">
                                    <Storyboard RepeatBehavior="Forever">

                                        <DoubleAnimation
                                            RepeatBehavior="Forever"
                                            Storyboard.TargetName="OuterRotateTransform"
                                            Storyboard.TargetProperty="Angle"
                                            From="0"
                                            To="360"
                                            Duration="0:0:4" />

                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CenterPulseTransform" Storyboard.TargetProperty="ScaleX">
                                            <SplineDoubleKeyFrame KeyTime="0:0:0.0" Value="1.0" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:0.9" Value="1.06" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.8" Value="1.0" />
                                        </DoubleAnimationUsingKeyFrames>

                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CenterPulseTransform" Storyboard.TargetProperty="ScaleY">
                                            <SplineDoubleKeyFrame KeyTime="0:0:0.0" Value="1.0" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:0.9" Value="1.06" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.8" Value="1.0" />
                                        </DoubleAnimationUsingKeyFrames>

                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ScanTranslateTransform" Storyboard.TargetProperty="Y">
                                            <SplineDoubleKeyFrame KeyTime="0:0:0.0" Value="0" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:0.9" Value="28" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.8" Value="0" />
                                        </DoubleAnimationUsingKeyFrames>

                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ScanLine" Storyboard.TargetProperty="Opacity">
                                            <SplineDoubleKeyFrame KeyTime="0:0:0.0" Value="0.12" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:0.9" Value="0.3" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.8" Value="0.12" />
                                        </DoubleAnimationUsingKeyFrames>

                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="StatusText" Storyboard.TargetProperty="Opacity">
                                            <SplineDoubleKeyFrame KeyTime="0:0:0.0" Value="0.7" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:0.9" Value="1.0" />
                                            <SplineDoubleKeyFrame KeyTime="0:0:1.8" Value="0.7" />
                                        </DoubleAnimationUsingKeyFrames>

                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>

                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="MonitoringOverlayStoryboard" />
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>