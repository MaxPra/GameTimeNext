<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Brush.TextBox.Background" Color="#14151A" />
    <SolidColorBrush x:Key="Brush.TextBox.BackgroundHover" Color="#171923" />
    <SolidColorBrush x:Key="Brush.TextBox.BackgroundFocused" Color="#161824" />

    <Thickness x:Key="Thickness.TextBox.Border">1</Thickness>
    <Thickness x:Key="Thickness.TextBox.BorderFocused">1.5</Thickness>

    <Style x:Key="TextBox.Default" TargetType="{x:Type TextBox}">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        <Setter Property="CaretBrush" Value="{DynamicResource Brush.TextPrimary}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource Brush.Accent}" />
        <Setter Property="SelectionOpacity" Value="0.35" />

        <Setter Property="Background" Value="{DynamicResource Brush.TextBox.Background}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="{DynamicResource Thickness.TextBox.Border}" />

        <Setter Property="Padding" Value="12,9" />
        <Setter Property="MinHeight" Value="38" />
        <Setter Property="FontSize" Value="13" />

        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden" />

        <Setter Property="Validation.ErrorTemplate" Value="{x:Null}" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Grid>
                        <Border
                            x:Name="Glow"
                            Background="Transparent"
                            CornerRadius="{StaticResource DefaultCornerRadius}"
                            IsHitTestVisible="False"
                            Opacity="0">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="18"
                                    Opacity="0.65"
                                    ShadowDepth="0"
                                    Color="#FF4D4F" />
                            </Border.Effect>
                        </Border>

                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource DefaultCornerRadius}"
                            SnapsToDevicePixels="True">

                            <Grid>
                                <Rectangle
                                    x:Name="Sheen"
                                    Margin="1"
                                    IsHitTestVisible="False"
                                    Opacity="0"
                                    RadiusX="2"
                                    RadiusY="2">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Offset="0" Color="#14FFFFFF" />
                                            <GradientStop Offset="1" Color="#00FFFFFF" />
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>

                                <ScrollViewer
                                    x:Name="PART_ContentHost"
                                    Margin="0"
                                    Focusable="False" />

                                <TextBlock
                                    x:Name="Watermark"
                                    Margin="{TemplateBinding Padding}"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource Brush.TextSecondary}"
                                    IsHitTestVisible="False"
                                    Opacity="0.70"
                                    Text="{TemplateBinding Tag}"
                                    Visibility="Collapsed" />
                            </Grid>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.TextBox.BackgroundHover}" />
                            <Setter TargetName="Sheen" Property="Opacity" Value="1" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.AccentHover}" />
                        </Trigger>

                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.TextBox.BackgroundFocused}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                            <Setter TargetName="Bd" Property="BorderThickness" Value="{DynamicResource Thickness.TextBox.BorderFocused}" />
                            <Setter TargetName="Glow" Property="Opacity" Value="1" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextDisabled}" />
                            <Setter TargetName="Bd" Property="Opacity" Value="0.65" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
                            <Setter TargetName="Glow" Property="Opacity" Value="0" />
                        </Trigger>

                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Danger}" />
                            <Setter TargetName="Bd" Property="BorderThickness" Value="{DynamicResource Thickness.TextBox.BorderFocused}" />
                            <Setter TargetName="Glow" Property="Opacity" Value="1" />
                            <Setter TargetName="Glow" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect
                                        BlurRadius="18"
                                        Opacity="0.75"
                                        ShadowDepth="0"
                                        Color="#E74C3C" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Text" Value="" />
                                <Condition Property="IsKeyboardFocusWithin" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Watermark" Property="Visibility" Value="Visible" />
                        </MultiTrigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style BasedOn="{StaticResource TextBox.Default}" TargetType="{x:Type TextBox}" />

</ResourceDictionary>