<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:Double x:Key="TileWidth">210</sys:Double>
    <sys:Double x:Key="TileHeight">300</sys:Double>
    <Thickness x:Key="TileGap">18</Thickness>

    <CornerRadius x:Key="TileCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="TileImageCornerRadius">6,6,0,0</CornerRadius>

    <!--  Dezent für Hover  -->
    <sys:Double x:Key="TileGlassOpacityNormal">0.10</sys:Double>
    <sys:Double x:Key="TileGlassOpacityHover">0.26</sys:Double>
    <sys:Double x:Key="TileSheenOpacityNormal">0</sys:Double>
    <sys:Double x:Key="TileSheenOpacityHover">0.35</sys:Double>

    <LinearGradientBrush x:Key="Brush.TileSheen" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#1AFFFFFF" />
        <GradientStop Offset="1" Color="#00FFFFFF" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.TileGlass" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#26FFFFFF" />
        <GradientStop Offset="0.35" Color="#10FFFFFF" />
        <GradientStop Offset="1" Color="#00FFFFFF" />
    </LinearGradientBrush>

    <!--
        Tile als ListBoxItem (Steam-like):
        - Hover: Glass + Sheen leicht höher, optional Schatten minimal stärker
        - Selected: nur blauer Border (kein Lift/Scale)
        - Schatten: immer
    -->
    <Style x:Key="TileListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">

                    <Border
                        x:Name="HitSurface"
                        Width="{StaticResource TileWidth}"
                        Height="{StaticResource TileHeight}"
                        Background="Transparent"
                        SnapsToDevicePixels="True">

                        <Grid x:Name="Root">

                            <!--  Schatten immer  -->
                            <Border
                                x:Name="ShadowLayer"
                                CornerRadius="{StaticResource TileCornerRadius}"
                                IsHitTestVisible="False"
                                Opacity="0.28">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="18"
                                        Opacity="1"
                                        ShadowDepth="8" />
                                </Border.Effect>
                            </Border>

                            <!--  Card  -->
                            <Border
                                x:Name="Card"
                                Background="{DynamicResource Brush.TileBackground}"
                                BorderBrush="{DynamicResource Brush.TileBorder}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource TileCornerRadius}"
                                SnapsToDevicePixels="True">

                                <Grid ClipToBounds="True">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="48" />
                                    </Grid.RowDefinitions>

                                    <!--  Image  -->
                                    <Border
                                        Grid.Row="0"
                                        ClipToBounds="True"
                                        CornerRadius="{StaticResource TileImageCornerRadius}">
                                        <Image
                                            RenderOptions.BitmapScalingMode="HighQuality"
                                            Source="{Binding PPFN}"
                                            Stretch="UniformToFill" />
                                    </Border>

                                    <!--  Top dark fade  -->
                                    <Rectangle
                                        Grid.Row="0"
                                        IsHitTestVisible="False"
                                        Opacity="0.85">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Offset="0" Color="#22000000" />
                                                <GradientStop Offset="0.22" Color="#00000000" />
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>

                                    <!--  Title  -->
                                    <Border
                                        Grid.Row="1"
                                        Padding="12,10"
                                        Background="{DynamicResource Brush.TileTitleBackground}"
                                        SnapsToDevicePixels="True">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource Brush.TileForeground}"
                                            Text="{Binding GANA}"
                                            TextTrimming="CharacterEllipsis" />
                                    </Border>

                                    <!--  Glass  -->
                                    <Rectangle
                                        x:Name="Glass"
                                        Grid.RowSpan="2"
                                        Fill="{StaticResource Brush.TileGlass}"
                                        IsHitTestVisible="False"
                                        Opacity="{StaticResource TileGlassOpacityNormal}" />

                                    <!--  Sheen  -->
                                    <Rectangle
                                        x:Name="Sheen"
                                        Grid.Row="0"
                                        Fill="{DynamicResource Brush.TileSheen}"
                                        IsHitTestVisible="False"
                                        Opacity="{StaticResource TileSheenOpacityNormal}" />

                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>

                        <!--  SELECTED: nur blauer Rand  -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource Brush.AccentHover}" />
                            <Setter TargetName="Card" Property="BorderThickness" Value="1" />
                        </Trigger>

                        <!--  Normal (nicht selected): normaler Rand  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="False" />
                                <Condition Property="IsMouseOver" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource Brush.TileBorder}" />
                        </MultiTrigger>

                        <!--  HOVER (nur wenn NICHT selected): Glass/Sheen dezent hoch  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsSelected" Value="False" />
                            </MultiTrigger.Conditions>

                            <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource Brush.TileBorder}" />

                            <MultiTrigger.EnterActions>
                                <BeginStoryboard x:Name="SbHoverIn" HandoffBehavior="SnapshotAndReplace">
                                    <Storyboard FillBehavior="HoldEnd">
                                        <DoubleAnimation
                                            Storyboard.TargetName="Glass"
                                            Storyboard.TargetProperty="Opacity"
                                            To="{StaticResource TileGlassOpacityHover}"
                                            Duration="0:0:0.10" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="Sheen"
                                            Storyboard.TargetProperty="Opacity"
                                            To="{StaticResource TileSheenOpacityHover}"
                                            Duration="0:0:0.10" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="ShadowLayer"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.34"
                                            Duration="0:0:0.10" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>

                            <MultiTrigger.ExitActions>
                                <BeginStoryboard x:Name="SbHoverOut" HandoffBehavior="SnapshotAndReplace">
                                    <Storyboard FillBehavior="HoldEnd">
                                        <DoubleAnimation
                                            Storyboard.TargetName="Glass"
                                            Storyboard.TargetProperty="Opacity"
                                            To="{StaticResource TileGlassOpacityNormal}"
                                            Duration="0:0:0.10" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="Sheen"
                                            Storyboard.TargetProperty="Opacity"
                                            To="{StaticResource TileSheenOpacityNormal}"
                                            Duration="0:0:0.10" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="ShadowLayer"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.28"
                                            Duration="0:0:0.10" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.ExitActions>
                        </MultiTrigger>

                        <!--  DISABLED  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
