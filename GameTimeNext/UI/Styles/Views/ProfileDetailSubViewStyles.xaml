<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:Double x:Key="ProfileDetail.CoverWidth">320</sys:Double>
    <sys:Double x:Key="ProfileDetail.CoverHeight">480</sys:Double>

    <Style x:Key="ProfileDetail.Root" TargetType="Grid">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="ProfileDetail.Container" TargetType="Grid">
        <Setter Property="Margin" Value="16" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="ProfileDetail.Layout" TargetType="DockPanel">
        <Setter Property="LastChildFill" Value="True" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Width" Value="520" />
        <Setter Property="MaxWidth" Value="760" />
    </Style>

    <!--  Card / Surface für mehr Tiefe  -->
    <Style x:Key="ProfileDetail.Card" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="Margin" Value="0,10,0,10" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!--  Dezente Accent-Line als visueller Anker  -->
    <Style x:Key="ProfileDetail.AccentLine" TargetType="Border">
        <Setter Property="Height" Value="2" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Background" Value="{DynamicResource Brush.Accent}" />
        <Setter Property="Opacity" Value="0.55" />
        <Setter Property="Margin" Value="0,0,0,16" />
    </Style>

    <!--  Subtile Vignette/Depth (nur DynamicResource Farben)  -->
    <Style x:Key="ProfileDetail.CardGlow" TargetType="Border">
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
        <Setter Property="Opacity" Value="0.10" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0" Color="{DynamicResource Color.Background}" />
                    <GradientStop Offset="1" Color="{DynamicResource Color.Surface}" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ProfileDetail.TopArea" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Vertical" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="ProfileDetail.Title" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextAlignment" Value="Center" />

        <Setter Property="TextWrapping" Value="NoWrap" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />

        <!--  verhindert hartes Clipping in manchen Layouts  -->
        <Setter Property="ClipToBounds" Value="True" />

        <!--  voller Titel bei Hover  -->
        <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
    </Style>

    <Style x:Key="ProfileDetail.CoverFrame" TargetType="Border">
        <Setter Property="Width" Value="{StaticResource ProfileDetail.CoverWidth}" />
        <Setter Property="Height" Value="{StaticResource ProfileDetail.CoverHeight}" />
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="Background" Value="{DynamicResource Brush.Surface}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="ProfileDetail.CoverImage" TargetType="Image">
        <Setter Property="Stretch" Value="UniformToFill" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!--  Overlay nur mit DynamicResource Farben  -->
    <Style x:Key="ProfileDetail.CoverOverlay" TargetType="Border">
        <Setter Property="VerticalAlignment" Value="Bottom" />
        <Setter Property="Height" Value="90" />
        <Setter Property="Opacity" Value="0.55" />
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0" Color="{DynamicResource Color.Background}" />
                    <GradientStop Offset="1" Color="{DynamicResource Color.Background}" />
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ProfileDetail.InfoHost" TargetType="Border">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Margin" Value="0,0,0,0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!--  Kleine Stats-Card für die Infos  -->
    <Style x:Key="ProfileDetail.InfoCard" TargetType="Border">
        <Setter Property="Width" Value="{StaticResource ProfileDetail.CoverWidth}" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="CornerRadius" Value="{StaticResource DefaultCornerRadius}" />
        <Setter Property="Background" Value="{DynamicResource Brush.Background}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Margin" Value="0,0,0,0" />
    </Style>

    <!--  Backward compatibility, falls noch verwendet  -->
    <Style x:Key="ProfileDetail.InfoBlock" TargetType="Border">
        <Setter Property="Width" Value="{StaticResource ProfileDetail.CoverWidth}" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="ProfileDetail.InfoLabel" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,4,0,4" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Left" />
    </Style>

    <Style x:Key="ProfileDetail.InfoValue" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Margin" Value="0,4,0,4" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextAlignment" Value="Left" />
    </Style>

    <Style
        x:Key="ProfileDetail.GameTimeLabel"
        BasedOn="{StaticResource ProfileDetail.InfoLabel}"
        TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Margin" Value="0,6,0,4" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    </Style>

    <Style
        x:Key="ProfileDetail.GameTimeValue"
        BasedOn="{StaticResource ProfileDetail.InfoValue}"
        TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,6,0,4" />
    </Style>

    <Style x:Key="ProfileDetail.ButtonHost" TargetType="Border">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Width" Value="{StaticResource ProfileDetail.CoverWidth}" />
        <Setter Property="Margin" Value="0,14,0,6" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="ProfileDetail.ButtonArea" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Vertical" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

</ResourceDictionary>