<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  ===== Base Colors =====  -->
    <Color x:Key="Color.Background">#0c0c0e</Color>
    <Color x:Key="Color.Surface">#18191b</Color>
    <Color x:Key="Color.Border">#60646c</Color>

    <Color x:Key="Color.TextPrimary">#FFF2F5F8</Color>
    <Color x:Key="Color.TextSecondary">#FFB7C0CC</Color>
    <Color x:Key="Color.TextDisabled">#FF6E7781</Color>

    <!--  ===== Accent Colors =====  -->
    <Color x:Key="Color.Accent">#3498e5</Color>
    <Color x:Key="Color.AccentHover">#2f96e4</Color>
    <Color x:Key="Color.AccentPressed">#1d8de2</Color>

    <Color x:Key="Color.TitleBarButton.Accent">#60646c</Color>

    <Color x:Key="Color.Success">#FF2ECC71</Color>
    <Color x:Key="Color.Warning">#FFF1C40F</Color>
    <Color x:Key="Color.Danger">#FFE74C3C</Color>

    <!--  ===== Brushes (für DynamicResource) =====  -->
    <SolidColorBrush x:Key="Brush.Background" Color="{DynamicResource Color.Background}" />
    <SolidColorBrush x:Key="Brush.Surface" Color="{DynamicResource Color.Surface}" />
    <SolidColorBrush x:Key="Brush.Border" Color="{DynamicResource Color.Border}" />

    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{DynamicResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{DynamicResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.TextDisabled" Color="{DynamicResource Color.TextDisabled}" />

    <SolidColorBrush x:Key="Brush.Accent" Color="{DynamicResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="{DynamicResource Color.AccentHover}" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="{DynamicResource Color.AccentPressed}" />

    <SolidColorBrush x:Key="Brush.TitleBarButton.Accent" Color="{DynamicResource Color.TitleBarButton.Accent}" />

    <SolidColorBrush x:Key="Brush.Success" Color="{DynamicResource Color.Success}" />
    <SolidColorBrush x:Key="Brush.Warning" Color="{DynamicResource Color.Warning}" />
    <SolidColorBrush x:Key="Brush.Danger" Color="{DynamicResource Color.Danger}" />

    <!--  ===== Tile / Card Brushes (Steam-like) =====  -->
    <SolidColorBrush x:Key="Brush.TileBackground" Color="{DynamicResource Color.Surface}" />
    <SolidColorBrush x:Key="Brush.TileBorder" Color="{DynamicResource Color.Border}" />
    <SolidColorBrush x:Key="Brush.TileForeground" Color="{DynamicResource Color.TextPrimary}" />

    <!--  untere Titel-Leiste  -->
    <SolidColorBrush x:Key="Brush.TileTitleBackground" Color="{DynamicResource Color.Background}" />

    <!--  Hover-Glanz (ohne neue Color.* Keys)  -->
    <SolidColorBrush x:Key="Brush.TileSheenTop" Color="#1AFFFFFF" />
    <SolidColorBrush x:Key="Brush.TileSheenBottom" Color="#00FFFFFF" />

</ResourceDictionary>
